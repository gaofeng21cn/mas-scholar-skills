{
  "contract_id": "mas_scholar_skills_display_pack_receipt_templates",
  "schema_version": "1.6.0",
  "owner": "MAS Scholar Skills Display",
  "state": "active_refs_only_template",
  "purpose": "Minimal refs-only handoff shapes for mandatory professional Figure Skill consumption, the medical figure contract, display-pack or paper-local generation receipt, fixed-canvas layout QC receipt, and visual QA receipt loop.",
  "machine_boundary": "These templates define candidate receipt vocabulary only. They do not authorize MAS domain truth, artifact mutation, owner receipts, typed blockers, current-package authority, publication readiness, or quality verdicts.",
  "authority_boundary": {
    "outputs_are_refs_only_candidates": true,
    "can_write_domain_truth": false,
    "can_mutate_artifact_body": false,
    "can_sign_owner_receipt": false,
    "can_create_typed_blocker": false,
    "can_claim_quality_verdict": false,
    "can_claim_publication_readiness": false,
    "can_claim_current_package_authority": false
  },
  "receipt_chain": [
    "professional_figure_workflow_ref",
    "figure_contract_ref",
    "render_or_generation_receipt_ref",
    "layout_qc_receipt_ref",
    "visual_qa_receipt_ref",
    "owner_gate_handoff_ref"
  ],
  "professional_figure_workflow_ref": {
    "schema_ref": "contracts/professional-figure-workflow.schema.json",
    "surface_kind": "mas_scholar_skills_professional_figure_workflow_candidate.v1",
    "new_or_materially_repaired_figure_requires": [
      "medical-figure-design"
    ],
    "final_visual_qa_requires": [
      "medical-figure-style"
    ],
    "conditional_skill_rules": {
      "assembled_panels_requires": "medical-figure-composer",
      "single_canvas_direct_forbids_invented_composer_receipt": true
    },
    "template_policy": {
      "template_use_is_optional": true,
      "template_is_reference_quality_floor_not_mandatory_layout": true,
      "record_provenance_only_when_template_used": true,
      "no_template_use_requires_only_decision_reason": true
    },
    "evidence_figure_text_policy": {
      "embedded_title": false,
      "embedded_subtitle": false,
      "embedded_prose_footer": false,
      "allowed_text_roles": [
        "panel_label",
        "axis_label",
        "tick_label",
        "legend",
        "necessary_statistical_annotation"
      ],
      "graphical_abstract_exempt": true
    },
    "semantic_flow_policy": {
      "pure_statistical_plot_may_declare_not_applicable": true,
      "declared_flow_or_schematic_requires_complete_semantic_artist_registry": true,
      "required_visible_artist_families": [
        "nodes",
        "bands",
        "brackets",
        "connector_segments",
        "arrowheads",
        "text"
      ],
      "connector_and_bracket_segments_require_renderer_path_geometry": true,
      "shared_junction_requires_common_renderer_path_prefix": true,
      "segmented_band_parent_connector_requires_exact_group_span_contract": true,
      "segmented_group_requires_full_span_labeled_midpoint_anchor": true,
      "segmented_group_requires_renderer_bound_actual_path_geometry": true,
      "unsupported_segmented_group_orientation_or_anchor_mode_fails_closed": true,
      "text_only_bbox_pass_is_sufficient": false,
      "hard_coded_zero_violation_counts_allowed": false
    },
    "missing_or_stale_receipt_behavior": {
      "blocks_stage_liveness": false,
      "creates_quality_debt": true,
      "blocks_quality_readiness": true,
      "blocks_export_readiness": true,
      "blocks_publication_readiness": true
    },
    "authority": false,
    "publication_ready": false
  },
  "template_asset_adaptation_policy": {
    "allowed_adaptation_modes": [
      "declared_template",
      "schema_adapted_template",
      "reference_guided_new_render",
      "original_new_render"
    ],
    "not_applicable_new_render_mapping": {
      "fixture_scope": "figure_or_panel_provenance_not_issued_render_receipt",
      "template_or_asset_ref": "not_applicable:new_render",
      "adaptation_mode": "original_new_render",
      "semantic_match_ref": "not_applicable:no_reusable_source",
      "transform_delta_ref": "not_applicable:no_reusable_source",
      "pack_render_receipt_requires_actual_outputs": true,
      "forbids_invented_reference_provenance": true
    },
    "warnings_remain_repair_hints": true,
    "hard_stop_conditions": [
      "missing_required_evidence",
      "missing_or_unreadable_artifact",
      "blank_artifact",
      "invalid_geometry",
      "unsupported_visible_claim",
      "hard_figure_contract_failure"
    ]
  },
  "figure_contract_ref": {
    "required_fields": [
      "contract_id",
      "figure_id",
      "core_conclusion_ref",
      "panel_evidence_chain_ref",
      "figure_archetype",
      "professional_figure_workflow_ref",
      "figure_text_policy_ref",
      "renderer_decision_ref",
      "journal_export_contract_ref",
      "forbidden_claim_drift",
      "owner_gate_handoff_ref"
    ],
    "template_selection_policy": {
      "required": false,
      "record_only_when_template_or_asset_is_used": true,
      "must_not_invent_template_provenance_for_original_render": true
    },
    "authority": false
  },
  "render_or_generation_receipt_ref": {
    "one_of": [
      "render_receipt_ref",
      "generation_receipt_ref"
    ],
    "exactly_one_required_per_figure": true
  },
  "render_receipt_ref": {
    "scope": "actual_display_pack_render_only",
    "required_fields": [
      "receipt_id",
      "figure_contract_ref",
      "pack_id",
      "template_id",
      "renderer_family",
      "execution_mode",
      "render_mode",
      "outputs",
      "layout_sidecar_ref",
      "template_or_asset_ref",
      "semantic_match_ref",
      "adaptation_mode",
      "transform_delta_ref",
      "source_data_ref",
      "degradation_reason",
      "known_limits",
      "authority",
      "publication_ready"
    ],
    "allowed_render_modes": [
      "final",
      "candidate"
    ],
    "allowed_adaptation_modes": [
      "declared_template",
      "schema_adapted_template",
      "reference_guided_new_render",
      "original_new_render"
    ],
    "degradation_reason_required_when_fidelity_reduced": true,
    "authority": false,
    "publication_ready": false
  },
  "generation_receipt_ref": {
    "scope": "paper_local_or_non_pack_render",
    "required_fields": [
      "receipt_id",
      "renderer_family",
      "renderer_version",
      "source_code_ref",
      "source_code_sha256",
      "input_manifest_ref",
      "input_manifest_sha256",
      "outputs"
    ],
    "required_artifact_formats": [
      "PNG",
      "PDF"
    ],
    "template_fields_required": false,
    "must_bind_exact_final_output_sha256": true,
    "authority": false,
    "publication_ready": false
  },
  "layout_qc_receipt_ref": {
    "surface_kind": "layout_qc_receipt_candidate.v1",
    "required_fields": [
      "receipt_id",
      "generation_source_ref",
      "registry_sha256",
      "artifact_bindings",
      "final_canvas",
      "safe_inset_px",
      "lane_bounds_px",
      "semantic_artist_scope",
      "bbox_registry_summary",
      "semantic_flow_summary",
      "checks",
      "violations",
      "regression_fixture_refs",
      "machine_check_status",
      "authority",
      "authority_boundary",
      "publication_ready"
    ],
    "required_artifact_formats": [
      "PNG",
      "PDF"
    ],
    "required_geometry_checks": [
      "registry_complete",
      "measured_wrap_valid",
      "annotation_lane_separate",
      "no_text_overlap",
      "minimum_spacing_met",
      "no_canvas_overflow",
      "no_clipping",
      "safe_inset_met",
      "semantic_artist_applicability_valid",
      "semantic_artist_registry_complete",
      "semantic_artist_kinds_complete",
      "semantic_artists_inside_canvas",
      "semantic_artists_inside_safe_inset",
      "semantic_node_text_contained",
      "semantic_contract_geometry_bound",
      "semantic_lines_clear_of_text",
      "semantic_lines_clear_of_unrelated_nodes",
      "semantic_connectors_non_crossing",
      "semantic_arrowheads_clear_of_text",
      "semantic_relation_encoding_valid",
      "semantic_arrow_budget_met",
      "semantic_incoming_unambiguous",
      "semantic_bracket_spans_exact",
      "semantic_segmented_group_spans_exact",
      "semantic_segmented_group_perceptual_anchors_valid",
      "fixed_canvas_export",
      "png_pdf_final_size_and_sha_bound"
    ],
    "export_policy": {
      "canvas_mode": "fixed",
      "matplotlib_bbox_inches": null,
      "equivalent_backend_policy": "fixed_canvas_no_tight_crop"
    },
    "allowed_machine_check_status": [
      "geometry_checks_passed",
      "geometry_checks_failed"
    ],
    "machine_check_is_quality_verdict": false,
    "authority": false,
    "authority_boundary": {
      "refs_only": true,
      "can_mutate_artifacts": false,
      "can_write_mas_truth": false,
      "can_sign_visual_audit_receipt": false,
      "can_sign_owner_receipt": false,
      "can_create_typed_blocker": false,
      "can_claim_mas_visual_authority": false,
      "can_claim_submission_authority": false,
      "can_claim_artifact_authority": false,
      "can_claim_quality_verdict": false,
      "can_claim_publication_readiness": false
    },
    "publication_ready": false
  },
  "visual_qa_receipt_ref": {
    "required_fields": [
      "receipt_id",
      "render_receipt_ref",
      "layout_qc_receipt_ref",
      "final_size_export_ref",
      "export_lint_ref",
      "final_size_grayscale_preview_ref",
      "color_vision_check_ref",
      "label_economy_ref",
      "professional_figure_style_invocation_ref",
      "final_output_artifact_bindings",
      "route_back_items",
      "owner_gate_handoff_ref",
      "authority",
      "publication_ready"
    ],
    "authority": false,
    "publication_ready": false
  }
}
