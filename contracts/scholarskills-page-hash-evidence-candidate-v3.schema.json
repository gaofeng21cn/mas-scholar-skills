{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.dev/contracts/scholarskills-page-hash-evidence-candidate-v3.schema.json",
  "title": "ScholarSkills Page Hash Evidence Candidate v3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "schema_version",
    "review_scope_sha256",
    "rubric_sha256",
    "evidence_payload",
    "cache_key_sha256",
    "origin_reviewer_evidence_ref"
  ],
  "properties": {
    "surface_kind": {
      "const": "scholarskills_page_hash_evidence_candidate"
    },
    "schema_version": {
      "const": 3
    },
    "review_scope_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "rubric_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "evidence_payload": {
      "$ref": "#/$defs/evidence_payload"
    },
    "cache_key_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "origin_reviewer_evidence_ref": {
      "oneOf": [
        {
          "$ref": "#/$defs/origin_ref"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "origin_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "ref",
        "size_bytes",
        "sha256"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "evidence_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raster_contract",
        "pages"
      ],
      "properties": {
        "raster_contract": {
          "$ref": "#/$defs/raster_contract"
        },
        "pages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/page"
          }
        }
      }
    },
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_number",
        "width",
        "height",
        "pixel_format",
        "pixel_sha256"
      ],
      "properties": {
        "page_number": {
          "type": "integer",
          "minimum": 1
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "pixel_format": {
          "const": "RGB8"
        },
        "pixel_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "raster_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_id",
        "contract_version",
        "scale_x",
        "scale_y",
        "nominal_dpi",
        "colorspace",
        "pixel_format",
        "alpha",
        "annotations",
        "hash_algorithm",
        "page_order"
      ],
      "properties": {
        "contract_id": {
          "const": "scholarskills_pdf_page_pixel_raster"
        },
        "contract_version": {
          "const": 1
        },
        "scale_x": {
          "const": 2.0
        },
        "scale_y": {
          "const": 2.0
        },
        "nominal_dpi": {
          "const": 144
        },
        "colorspace": {
          "const": "sRGB"
        },
        "pixel_format": {
          "const": "RGB8"
        },
        "alpha": {
          "const": false
        },
        "annotations": {
          "const": true
        },
        "hash_algorithm": {
          "const": "sha256"
        },
        "page_order": {
          "const": "document_order"
        }
      }
    }
  }
}
