{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.dev/contracts/mas-scholar-skills-professional-figure-workflow.schema.json",
  "title": "MAS Scholar Skills professional figure workflow candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "schema_ref",
    "schema_version",
    "workflow_id",
    "generation_id",
    "package_identity",
    "figures",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": {
      "const": "mas_scholar_skills_professional_figure_workflow_candidate.v1"
    },
    "schema_ref": {
      "const": "contracts/professional-figure-workflow.schema.json"
    },
    "schema_version": {
      "const": 1
    },
    "workflow_id": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "generation_id": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "package_identity": {
      "$ref": "#/$defs/packageIdentity"
    },
    "figures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/figureRecord"
      }
    },
    "authority_boundary": {
      "$ref": "#/$defs/authorityBoundary"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "packageIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_id",
        "version",
        "source_ref",
        "source_sha256"
      ],
      "properties": {
        "package_id": {
          "const": "mas-scholar-skills"
        },
        "version": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "source_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "source_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "artifactBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "format",
        "path_ref",
        "size_bytes",
        "sha256"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "format": {
          "enum": [
            "PNG",
            "PDF"
          ]
        },
        "path_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "skillInvocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_id",
        "skill_id",
        "skill_source_ref",
        "skill_version",
        "skill_sha256",
        "invocation_id",
        "input_contract_ref",
        "input_sha256",
        "consumed_rule_refs",
        "output_artifacts",
        "status",
        "refs_only",
        "authority",
        "publication_ready"
      ],
      "properties": {
        "receipt_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "skill_id": {
          "enum": [
            "medical-figure-design",
            "medical-figure-style",
            "medical-figure-composer"
          ]
        },
        "skill_source_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "skill_version": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "skill_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "invocation_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "input_contract_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "input_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "consumed_rule_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "output_artifacts": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/artifactBinding"
          }
        },
        "status": {
          "const": "completed"
        },
        "refs_only": {
          "const": true
        },
        "authority": {
          "const": false
        },
        "publication_ready": {
          "const": false
        }
      }
    },
    "templateUsage": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "used",
            "decision_reason"
          ],
          "properties": {
            "used": {
              "const": false
            },
            "decision_reason": {
              "$ref": "#/$defs/nonEmptyString"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "used",
            "template_id",
            "template_ref",
            "adaptation_mode",
            "semantic_match_ref",
            "transform_delta_ref"
          ],
          "properties": {
            "used": {
              "const": true
            },
            "template_id": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "template_ref": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "adaptation_mode": {
              "enum": [
                "declared_template",
                "schema_adapted_template",
                "reference_guided_new_render"
              ]
            },
            "semantic_match_ref": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "transform_delta_ref": {
              "$ref": "#/$defs/nonEmptyString"
            }
          }
        }
      ]
    },
    "textPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "embedded_title",
        "embedded_subtitle",
        "embedded_prose_footer",
        "allowed_text_roles"
      ],
      "properties": {
        "embedded_title": {
          "type": "boolean"
        },
        "embedded_subtitle": {
          "type": "boolean"
        },
        "embedded_prose_footer": {
          "type": "boolean"
        },
        "allowed_text_roles": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "panel_label",
              "axis_label",
              "tick_label",
              "legend",
              "necessary_statistical_annotation",
              "graphical_abstract_copy"
            ]
          }
        }
      }
    },
    "generationReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_id",
        "renderer_family",
        "renderer_version",
        "source_code_ref",
        "source_code_sha256",
        "input_manifest_ref",
        "input_manifest_sha256",
        "outputs"
      ],
      "properties": {
        "receipt_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "renderer_family": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "renderer_version": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "source_code_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "source_code_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "input_manifest_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "input_manifest_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "outputs": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/artifactBinding"
          }
        }
      }
    },
    "figureRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "figure_id",
        "figure_kind",
        "composition_mode",
        "figure_contract_ref",
        "template_usage",
        "text_policy",
        "design_invocation",
        "generation_receipt",
        "style_invocation",
        "outputs"
      ],
      "properties": {
        "figure_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "figure_kind": {
          "enum": [
            "evidence_figure",
            "graphical_abstract"
          ]
        },
        "composition_mode": {
          "enum": [
            "single_canvas_direct",
            "assembled_panels"
          ]
        },
        "figure_contract_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "template_usage": {
          "$ref": "#/$defs/templateUsage"
        },
        "text_policy": {
          "$ref": "#/$defs/textPolicy"
        },
        "design_invocation": {
          "$ref": "#/$defs/skillInvocation"
        },
        "generation_receipt": {
          "$ref": "#/$defs/generationReceipt"
        },
        "composer_invocation": {
          "$ref": "#/$defs/skillInvocation"
        },
        "style_invocation": {
          "$ref": "#/$defs/skillInvocation"
        },
        "outputs": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/artifactBinding"
          }
        }
      }
    },
    "authorityBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "refs_only",
        "can_mutate_artifacts",
        "can_sign_owner_receipt",
        "can_create_typed_blocker",
        "can_claim_quality_readiness",
        "can_claim_export_readiness",
        "can_claim_publication_readiness"
      ],
      "properties": {
        "refs_only": {
          "const": true
        },
        "can_mutate_artifacts": {
          "const": false
        },
        "can_sign_owner_receipt": {
          "const": false
        },
        "can_create_typed_blocker": {
          "const": false
        },
        "can_claim_quality_readiness": {
          "const": false
        },
        "can_claim_export_readiness": {
          "const": false
        },
        "can_claim_publication_readiness": {
          "const": false
        }
      }
    }
  }
}
