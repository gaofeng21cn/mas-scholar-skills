{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.dev/contracts/reference-provider-adapter-registry.schema.json",
  "title": "ScholarSkills reference provider adapter registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "schema_ref",
    "package_id",
    "module_id",
    "module_kind",
    "adapter_abi",
    "profile_ref",
    "step_schema_ref",
    "handler",
    "state_machine_exports",
    "max_steps",
    "adapters",
    "contained_implementation_files",
    "sandbox",
    "no_authority_boundary"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_connect_reference_provider_adapter_registry.v1"
    },
    "schema_ref": {
      "const": "contracts/reference-provider-adapters/reference-provider-adapter-registry.schema.json"
    },
    "package_id": {
      "const": "mas-scholar-skills"
    },
    "module_id": {
      "const": "mas-scholar-skills.reference-provider-adapters"
    },
    "module_kind": {
      "const": "opl_connect_reference_provider_adapter"
    },
    "adapter_abi": {
      "const": "opl-connect-reference-provider-adapter.v1"
    },
    "profile_ref": {
      "const": "contracts/reference-provider-adapters/scientific-metadata.json"
    },
    "step_schema_ref": {
      "const": "contracts/reference-provider-adapters/reference-provider-adapter-step.schema.json"
    },
    "handler": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "file",
        "export"
      ],
      "properties": {
        "kind": {
          "const": "typescript_export"
        },
        "file": {
          "const": "runtime/reference-provider-adapters/index.ts"
        },
        "export": {
          "const": "runReferenceProviderAdapterStep"
        }
      }
    },
    "state_machine_exports": {
      "const": [
        "build_request",
        "parse_response",
        "next_step"
      ]
    },
    "max_steps": {
      "const": 2
    },
    "adapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "adapter_id",
          "initial_step",
          "max_steps",
          "response_kinds"
        ],
        "properties": {
          "adapter_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_]*$"
          },
          "initial_step": {
            "type": "string",
            "minLength": 1
          },
          "max_steps": {
            "type": "integer",
            "minimum": 1,
            "maximum": 2
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "response_kinds": {
            "type": "array",
            "items": {
              "enum": [
                "json",
                "text"
              ]
            }
          }
        },
        "additionalProperties": false
      }
    },
    "contained_implementation_files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^runtime/reference-provider-adapters/"
      }
    },
    "sandbox": {
      "type": "object",
      "additionalProperties": true
    },
    "no_authority_boundary": {
      "type": "object",
      "additionalProperties": {
        "const": false
      },
      "minProperties": 1
    }
  }
}
