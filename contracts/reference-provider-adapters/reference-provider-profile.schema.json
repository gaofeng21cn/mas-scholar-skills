{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.dev/contracts/reference-provider-profile.schema.json",
  "title": "ScholarSkills scientific reference provider profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "schema_ref",
    "profile_id",
    "profile_role",
    "registry_owner",
    "provider_ontology_owner",
    "adapter_package",
    "default_provider_ids",
    "providers",
    "no_authority_boundary"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_connect_reference_provider_profile.v1"
    },
    "schema_ref": {
      "const": "contracts/reference-provider-adapters/reference-provider-profile.schema.json"
    },
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "profile_role": {
      "const": "optional_connector_profile"
    },
    "registry_owner": {
      "const": "mas-scholar-skills.reference-provider-adapters"
    },
    "provider_ontology_owner": {
      "const": "profile_not_framework_core"
    },
    "adapter_package": {
      "$ref": "#/$defs/adapterPackage"
    },
    "default_provider_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/provider"
      }
    },
    "no_authority_boundary": {
      "$ref": "#/$defs/noAuthorityBoundary"
    }
  },
  "$defs": {
    "adapterPackage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_id",
        "module_id",
        "package_role",
        "adapter_abi",
        "registry_ref",
        "handler_ref",
        "adapter_ids",
        "byte_authority"
      ],
      "properties": {
        "package_id": {
          "const": "mas-scholar-skills"
        },
        "module_id": {
          "const": "mas-scholar-skills.reference-provider-adapters"
        },
        "package_role": {
          "const": "capability_package_runtime_module"
        },
        "adapter_abi": {
          "const": "opl-connect-reference-provider-adapter.v1"
        },
        "registry_ref": {
          "const": "contracts/reference-provider-adapters/reference-provider-adapter-registry.json"
        },
        "handler_ref": {
          "const": "runtime/reference-provider-adapters/index.ts#runReferenceProviderAdapterStep"
        },
        "adapter_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_]*$"
          }
        },
        "byte_authority": {
          "const": "installed_capability_package_source_commit_and_content_digest"
        }
      }
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_id",
        "adapter_id",
        "receipt_provider_name",
        "aliases",
        "endpoint",
        "verification_scope"
      ],
      "properties": {
        "provider_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "adapter_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_]*$"
        },
        "receipt_provider_name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_]*$"
        },
        "aliases": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "endpoint": {
          "$ref": "#/$defs/endpoint"
        },
        "verification_scope": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": true
        }
      }
    },
    "endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_base_url",
        "environment_override",
        "allowed_origins"
      ],
      "properties": {
        "default_base_url": {
          "type": "string",
          "pattern": "^https://"
        },
        "environment_override": {
          "type": "string",
          "pattern": "^OPL_CONNECT_[A-Z0-9_]+$"
        },
        "allowed_origins": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^https://[^/]+$"
          }
        }
      }
    },
    "noAuthorityBoundary": {
      "type": "object",
      "additionalProperties": {
        "const": false
      },
      "minProperties": 1
    }
  }
}
